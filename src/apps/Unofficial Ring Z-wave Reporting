                for (var i = 0; i < cells.length; i++) {
                    var cell = cells[i];
                    var cellTime = parseFloat(cell.getAttribute('data-time')) || 0;

                    if (!foundRecent && cellTime < tRecent) {
                        if (tAncient > 0 && cellTime < tAncient) {
                            // Hit both boundaries on the exact same gap
                            cell.classList.add('marker-collision');
                            foundRecent = true;
                            foundAncient = true;
                        } else {
                            cell.classList.add('marker-recent');
                            foundRecent = true;
                        }
                    }
					if (foundRecent && !foundAncient && tAncient > 0 && cellTime < tAncient) {
                        cell.classList.add('marker-ancient');
                        foundAncient = true;
                    }

                    if (foundRecent && (times.length < 2 || foundAncient)) break;
                }
            });
