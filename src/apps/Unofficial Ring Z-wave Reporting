        //DELME html << "${nameLabel} <span style='font-size: 11px; color: #888; margin-left:5px;'>(Last changed ${getTimeAgo(row.lastUpdateMs)} ${row.lastUpdateAbs ?: ''})</span></td>"
        html << "${nameLabel} <span style='font-size: 11px; color: #888; margin-left:5px;'>${activityStr}</span></td>"
        html << "<td data-sort='${row.rssi}' style='padding: 6px 10px; text-align: right; font-weight: bold; color: ${row.color}; font-size: 14px;'>${row.rssi}</td>"
        
        // ADDED: white-space: nowrap; overflow-x: auto; to enforce the strict CSS Grid approach
        html << "<td data-sort='${row.hScore}' style='padding: 6px 10px 6px 20px; font-size: 18px; line-height: 1; white-space: nowrap; overflow-x: auto;'>${row.historyHtml}</td>"
        html << "</tr>"

