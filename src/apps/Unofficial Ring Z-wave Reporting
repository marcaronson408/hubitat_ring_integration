                var label = box.querySelector('div');
                var targetHeight = table.getBoundingClientRect().height + label.getBoundingClientRect().height + 60;
                box.style.height = targetHeight + 'px';
                box.style.overflow = 'hidden';
            }
        }, 200);
    </script>
    """
    logTime("Finished big chunk 2")
    html << "</div>"
    logTime("Exit GenerateHistoryReport")
    return html.join("")
}


def prepareDeviceData(threshold) {
    logTime("Enter prepareDeviceData")
    def reportRows = []
    def nowMs = now().toLong()
    def zidLookup = [:]
    def metadataLookup = [:] 
    def extenderToClients = [:] 
    def globalLatestNodeId = [:]
    
    // 1. Map Devices and capture their Node IDs and LIVE signal snapshot
    parent.getAllRingDevices().each { dev ->
        def devLabel = "Unknown Device"
        try {
            def allData = parent.getDeviceInfo2(dev)
            def devInfo = allData?.info
            def sigData = allData?.signal
            if (!devInfo) return
            
            def cleanZid = devInfo.zidLower
            devLabel = devInfo.label ?: devInfo.name ?: "Node ${devInfo.nodeId}"

            // Filter out devices with no signal data
            if (!cleanZid || cleanZid == "" || !sigData || sigData == "[]" || sigData == "" || sigData == "ALARM_HUB") {
                logDebug "Skipping device ${devLabel}"
                return
            }

            def nodeId = devInfo.nodeId?.toString()?.trim()
            def hubId = devInfo.id
            
            // Fallback for nodeId
            if (!nodeId && state.zidNodeidMap) {
                nodeId = state.zidNodeidMap.find { it.value == cleanZid }?.key
            }
            
            // PRE-CALCULATE neighbor data before building the Map
            def bestRssi = -128
            def bestQual = false
            def foundAnyNeighbor = false
            def neighborList = []

            try {
                def rawNeighbors = (sigData instanceof List) ? sigData : new groovy.json.JsonSlurper().parseText(sigData)
                rawNeighbors.each { n ->
                    def currentRssi = rssiNormalize(n.rssi)
                    
                    // Keep the strongest signal (closest to 0)
                    if (!foundAnyNeighbor || currentRssi > bestRssi) {
                        bestRssi = currentRssi
                        bestQual = (n.quality == "ok")
                        foundAnyNeighbor = true
                    }

                    def cleanNZid = n.zid?.toString()
                    if (cleanNZid && cleanNZid != "1" && cleanZid) {
                        if (!extenderToClients[cleanNZid]) extenderToClients[cleanNZid] = []
                        if (!extenderToClients[cleanNZid].contains(cleanZid)) extenderToClients[cleanNZid] << cleanZid
                    }

                    def nName = (n.nodeId == 1 || n.nodeId == "1") ? "Hub" : (state.deviceInfo[cleanNZid]?.name ?: "Node ${n.nodeId}")
                    neighborList << [zid: cleanNZid, name: nName, rssi: currentRssi, quality: n.quality, status: n.status]
                }
            } catch (innerE) {
                log.warn "Could not parse neighbors for ${devLabel}: ${innerE}"
            }
            
            // Create the entry Map ONCE with all data already present
            // This avoids the NPE "Cannot set property on null object"
            def entry = [
                hubId: hubId, 
                nodeId: nodeId, 
                neighbors: neighborList, 
                lastActivity: dev.lastActivity, // Using device object activity
                snapshotRssi: bestRssi, 
                snapshotQuality: bestQual
            ]
            
            if (cleanZid && devLabel) {
                if (state.deviceInfo[cleanZid] == null) {
                    state.deviceInfo[cleanZid] = [name: devLabel, firstRecord: null, lastChange: null]
                } else {
                    state.deviceInfo[cleanZid].name = devLabel
                }
            }

            // Save to lookup maps
            if (cleanZid) zidLookup[cleanZid] = entry
            if (nodeId) zidLookup[nodeId] = entry
            
        } catch (e) { 
            log.error "CRITICAL ERROR processing ${devLabel}: ${e}. Check device in Ring App."
        }
    }
    
    logTime("prepareDeviceData start section 2")

    // 2. Process History to find current actual paths
    state.rssiHistory.each { zid, history ->
        if (!history) return
        def lookupId = zid.toString()
                
        def info = state.deviceInfo[zid] 
        def name = info?.name ?: "Unknown (${lookupId})"
        def devEntry = zidLookup[lookupId]
        
        def lastUpdate = info?.lastChange ?: 0
        def firstMs = info?.firstRecord

        def latestData = decodeRSSIHistory(history[0] as int)
        def latestNId = latestData.nodeId.toString().trim()
        globalLatestNodeId[lookupId] = latestNId
        
        // Use Live Snapshot if found, otherwise fall back to history data
        def liveRssi = (devEntry && devEntry.snapshotRssi != -128) ? devEntry.snapshotRssi : latestData.rssi
        def liveQual = (devEntry && devEntry.snapshotRssi != -128) ? devEntry.snapshotQuality : (latestData.quality == 1)

        def emojiList = []
        int reds = 0, yellows = 0, greens = 0, limes = 0 
        def rowLastUpdateStr = ""
        
        history.each { packed ->
            def d = decodeRSSIHistory(packed as int)
            def nId = d.nodeId
            def nIdStr = nId.toString()
            def val = d.rssi
            def elapsedMins = d.minutes

            if (nId > 1) {
                def pathZid = state.zidNodeidMap ? state.zidNodeidMap[nIdStr] : null
                if (pathZid) {
                    if (!extenderToClients[pathZid]) extenderToClients[pathZid] = []
                    if (!extenderToClients[pathZid].contains(lookupId)) extenderToClients[pathZid] << lookupId
                }
            }
                
            def pathName = (nId == 1) ? "Hub" : "Node ${nId}"
            if (nId > 1 && state.zidNodeidMap) {
                def pathZid = state.zidNodeidMap[nIdStr] 
                if (pathZid) pathName = state.deviceInfo[pathZid]?.name ?: pathName
            }
            
            def timeAgoStr = "Unknown"
            def dateTimeStr = ""
            def eventTimeMs = 0
            if (firstMs) {
                eventTimeMs = firstMs.toLong() + (elapsedMins * 60000)
                def minsAgo = Math.max(0, ((nowMs - eventTimeMs) / 60000).toInteger())
                timeAgoStr = minsAgo < 60 ? "${minsAgo}m ago" : "${(minsAgo / 60).toInteger()}h ${minsAgo % 60}m ago"
                dateTimeStr = new Date(eventTimeMs).format("'on' M/d 'at' h:mm a")
            }
            
            def pathKey = "${lookupId}-${nIdStr}".toString()
            if (!metadataLookup.containsKey(pathKey)) {
                metadataLookup[pathKey] = [rssi: val, time: timeAgoStr, dateTime: dateTimeStr, color: getSignalColor(val, threshold, d.quality == 1), timeMs: eventTimeMs]
            }
            
            if (packed == history[0]) {
                metadataLookup[lookupId] = metadataLookup[pathKey]
                rowLastUpdateStr = dateTimeStr
            }

            def icon = getSignalIcon(val, nId > 1, threshold, d.quality == 1)
            
            if (val < threshold - 10 && d.quality != 1) reds++ 
            else if (val < threshold - 10 && d.quality == 1) yellows++ 
            else if (val < threshold) limes++ 
            else greens++ 

            def qStatus = (d.quality == 1) ? "OK" : "Bad"
            def hoverText = "${pathName}: ${val}dBm (${qStatus}) | ${timeAgoStr} ${dateTimeStr}"

            def spanStyle = "display:inline-block; width:32px; text-align:center; box-sizing:border-box; line-height:1; cursor:zoom-in; margin-right:4px; border-left:3px solid transparent; margin-left:-3px; padding-left:3px; transition:border-color 0.2s ease"
            emojiList << "<span class='grid-cell' data-time='${eventTimeMs}' title='${hoverText}' style='${spanStyle}'>${icon}</span>"
        }
        
        reportRows << [
            zid: lookupId, lastActivity: devEntry?.lastActivity,
            name: name, rssi: liveRssi, lastUpdateMs: lastUpdate,
            lastUpdateAbs: rowLastUpdateStr,
            historyHtml: emojiList.join(""), 
            hubId: devEntry?.hubId, nodeId: devEntry?.nodeId,
            color: getSignalColor(liveRssi, threshold, liveQual),
            hScore: -(Math.min(9, reds) * 1000 + Math.min(9, yellows) * 10 + Math.min(9,limes)) + Math.min(9, greens),
            neighbors: devEntry?.neighbors ?: [], inboundClients: []
        ]
    }
    
    logTime("prepareDeviceData start section 3")
    
    // 3. Flag Stale Inbound Clients
    reportRows.each { row ->
        def clients = extenderToClients[row.zid]
        if (clients) {
            def thisExtenderNodeId = row.nodeId?.toString()?.trim() ?: state.zidNodeidMap?.find { it.value == row.zid }?.key
            clients.each { cZid ->
                def meta = metadataLookup["${cZid}-${thisExtenderNodeId}".toString()] ?: metadataLookup[cZid]
                def currentActualPath = globalLatestNodeId[cZid]?.toString()?.trim()
                def isStale = (currentActualPath && thisExtenderNodeId && currentActualPath != thisExtenderNodeId)

                row.inboundClients << [
                    name: state.deviceInfo[cZid]?.name ?: "Unknown",
                    rssi: meta?.rssi ?: 0,
                    color: meta?.color ?: "#444",
                    isStale: isStale,
                    timeStr: "${meta?.time ?: 'N/A'} ${meta?.dateTime ?: ''}",
                    timeMs: meta?.timeMs ?: 0
                ]
            }
            row.inboundClients.sort { a, b ->
                if (a.isStale != b.isStale) return a.isStale <=> b.isStale
                return b.timeMs <=> a.timeMs
            }
        }
    }
    logTime("Exit prepareDeviceData")
    return reportRows.sort { it.hScore }
}


def buildDeviceTable(reportRows, threshold) {
    def html = []
    html << """
    <table id='historyTable' style='width: 100%; border-collapse: collapse; table-layout: fixed;'>
    <tr style='background: #444; color: white; font-size: 12px;'>
        <th style='padding: 8px 10px; text-align: left; width: 45%; white-space: nowrap;'>
            Device ( <span onclick='sortHistoryTable(0, "string")' style='cursor:pointer; text-decoration:underline;'>Name ↕</span> | <span onclick='sortHistoryTable(0, "time")' style='cursor:pointer; text-decoration:underline;'>Time ↕</span> )
        </th>
        <th onclick='sortHistoryTable(1, "number")' style='padding: 8px 10px; text-align: right; width: 12%; cursor: pointer;'>dBm ↕</th>
        <th onclick='sortHistoryTable(2, "number")' style='padding: 8px 10px 8px 20px; text-align: left; cursor: pointer;'>History ↕</th>
    </tr>
    """
    
    reportRows.eachWithIndex { row, i ->
        def rowBg = (i % 2 == 0) ? "#ffffff" : "#f9f9f9"
        def nameLabel = row.hubId ? "<a href='/device/edit/${row.hubId}' target='_blank' style='color: #007bff; text-decoration: none; font-weight: bold;'>${row.name}</a>" : "<b>${row.name}</b>"

        // We initialize sortTime with the old Z-wave time as a fallback
        def sortTime = row.lastUpdateMs 
        def activityStr = "(Last changed ${getTimeAgo(row.lastUpdateMs)} ${row.lastUpdateAbs ?: ''})"
        
        if (row.lastActivity instanceof Date) {
            // Update sortTime to the new, more accurate platform time
            sortTime = row.lastActivity.time 
            long diffMs = now().toLong() - sortTime
            if (diffMs >= 0) {
                long d = diffMs / 86400000
                long h = (diffMs % 86400000) / 3600000
                long m = (diffMs % 3600000) / 60000
                def dur = (d > 0 ? "${d}d " : "") + ((h > 0 || d > 0) ? "${h}h " : "") + "${m}m"
                def dateStr = row.lastActivity.format("M/d 'at' h:mm a", location.timeZone)
                activityStr = "(Last changed ${dur} ago on ${dateStr})"
            }
        }
        
        html << "<tr class='history-row' data-zid='${row.zid}' style='border-bottom: 1px solid #eee; background-color: ${rowBg};'>"
        html << "<td data-sort='${row.name.replace("'", "&#39;")}' data-time='${sortTime}' class='device-name' style='padding: 6px 10px; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;'>"
