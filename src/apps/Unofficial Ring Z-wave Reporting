def captureSignalHistory() {
    lastLogTime = 0
    logTime("Starting captureSignalHistory")
    if (state.rssiHistory == null) state.rssiHistory = [:]
    if (state.zidNodeidMap == null) state.zidNodeidMap = [:]
    if (state.deviceInfo == null) state.deviceInfo = [:]
    logDebug "--- Starting Signal History Capture ---"
    
    def interval = (settings.historyInterval ?: 15).toInteger()
    runIn(interval * 60, "captureSignalHistory")
    
    def allDevs = parent.getAllRingDevices()

    allDevs.each { dev ->
		def allData = parent.getDeviceInfo2(dev)
        def devInfo = allData?.info
        def sigData = allData?.signal
        if (!devInfo) return
        
        def zid = devInfo.zidLower
        if (!zid || zid == "" || !sigData || sigData == "[]" || sigData == "" || sigData == "ALARM_HUB") {
            logDebug "Skipping device ${devInfo.name ?: 'Unknown' } "
            return
        }
        def type = devInfo.typeName ?: ""
        def displayName = devInfo.name ?: "Unknown"
        
        // Hopefully this never happens and this block can be deleted.
        if (type.contains("API"))  {
            log.debug "Mysterious type API ${displayName} ${allData}"
            return
        }

        def info = state.deviceInfo[zid]
        if (info == null) {
            state.deviceInfo[zid] = [name: displayName, firstRecord: null, lastChange: null]
        } else if (info.name != displayName) {
            info.name = displayName
            state.deviceInfo[zid] = info // (one write)
        }

        // 2. PROCESS PATHS & HISTORY
        try {
            def json = (sigData instanceof String) ? new groovy.json.JsonSlurper().parseText(sigData) : sigData

            def localDeviceInfo = state.deviceInfo ?: [:]
            def localZidMap = state.zidNodeidMap ?: [:]
            boolean infoChanged = false
            boolean zidChanged = false

            // Update ZID/NodeID Mapping for the whole mesh.
            // Deal with positive RSSI values.
            // Build the list of valid pathes.
            def validPaths = []
            json.each { path ->
                if (path.rssi != null) {
                    path.rssi = rssiNormalize(path.rssi)
                    validPaths << path
                }
                if (path.zid && path.nodeId != null) {
                    def nIdStr = path.nodeId.toString()

                    if (!localZidMap.containsKey(nIdStr)) {
                        localZidMap[nIdStr] = path.zid
                        zidChanged = true
                    }

                    if (path.name) {
                        def info2 = localDeviceInfo[path.zid]
                        if (info2 == null) {
                            localDeviceInfo[path.zid] = [name: path.name, firstRecord: null, lastChange: null]
                            infoChanged = true
                        } else if (info2.name != path.name) {
                            info2.name = path.name
                            infoChanged = true
                        }
                    }
                }
            }

            if (infoChanged) state.deviceInfo = localDeviceInfo
            if (zidChanged) state.zidNodeidMap = localZidMap

            // Proceed with History Recording
            if (validPaths) {
                def bestPath = validPaths.max { it.rssi.toInteger() }
                def rssi = Math.abs(bestPath.rssi.toInteger())
                def nodeId = bestPath.nodeId ? bestPath.nodeId.toInteger() : 1
                def rawStatus = bestPath?.status?.toString()?.toLowerCase() ?: "unknown"
                def rawQuality = bestPath?.quality?.toString()?.toLowerCase() ?: "unknown"
                def status = bestPath?.status ?: "UNKNOWN"

                def currentQual = (rawQuality == "ok" && rawStatus == "valid") ? 1 : 0

                def historyList = state.rssiHistory[zid] ?: []

                // Anchor the entire device logic to its physical check-in time
                def nowMs = dev.lastActivity?.getTime() ?: now()

                if (state.deviceInfo[zid].firstRecord == null) {
                    state.deviceInfo[zid].firstRecord = nowMs
                }

                def startTs = state.deviceInfo[zid].firstRecord ?: nowMs
                int elapsedMins = Math.min(9999, ((nowMs - startTs) / 60000).toInteger())
                def packedValue = encodeRSSIHistory(nodeId, currentQual, rssi, elapsedMins)// 1. Get the most recent stored record for comparison
                def lastData = historyList ? decodeRSSIHistory(historyList[0] as int) : null

				// 2. Comparison Logic (Using Math.abs to prevent 69 vs -69 mismatch)
                boolean nodeMatch = lastData ? (nodeId == lastData.nodeId) : false
                boolean rssiMatch = lastData ? (Math.abs(rssi) == Math.abs(lastData.rssi)) : false
                boolean qualMatch = lastData ? (currentQual == lastData.quality) : false
                boolean isDataChanged = !lastData || !nodeMatch || !rssiMatch || !qualMatch

                // 3. Verbose Debugging
                if (lastData) {
                    logDebug "${displayName} Comparison -> " +
                              "NODE: [Live:${nodeId} vs Stored:${lastData.nodeId}] (${nodeMatch}), " +
                              "RSSI: [Live:${rssi} vs Stored:${lastData.rssi}] (${rssiMatch}), " +
                              "QUAL: [Live:${currentQual} vs Stored:${lastData.quality}] (${qualMatch})"
                } else {
                    logDebug "${displayName} Comparison -> No stored data found (isNew)"
                }

                // 4. Execution Logic

                if (isDataChanged || !settings.onlyRecordChanges) {
                    logDebug "RSSI History ACTION: ADD NEW ICON (Change:${isDataChanged}, SettingOnlyRecord:${settings.onlyRecordChanges})"

                    if (state.deviceInfo[zid] == null) {
                        state.deviceInfo[zid] = [name: (displayName ?: "Unknown"), firstRecord: nowMs, lastChange: nowMs]
                    } else {
                        state.deviceInfo[zid].lastChange = nowMs
                    }


                    historyList.add(0, packedValue)
                    // Overflow Logic
                    if (historyList.size() > 12) {
                        historyList = historyList.take(12)
                        def shiftMins = decodeRSSIHistory(historyList[-1] as int).minutes

                        def newFirstTime = state.deviceInfo[zid].firstRecord + (shiftMins * 60000)
                        if (state.deviceInfo[zid]) state.deviceInfo[zid].firstRecord = newFirstTime
                        historyList = historyList.collect { p ->
                            def d = decodeRSSIHistory(p as int)
                            return encodeRSSIHistory(d.nodeId, d.quality, d.rssi, Math.max(0, d.minutes - shiftMins))
                        }
                    }
                } else {
                    // Data hasn't changed, so we do NOT update historyList[0].
                    // This anchors the icon to the minute it was first recorded.
                    logDebug "RSSI History: No change for ${displayName}. Keeping original timestamp."
                    // historyList[0] = packedValue
                }
                state.rssiHistory[zid] = historyList
            }
        } catch (e) { log.error "Capture Error for ${displayName}: ${e}" }
    }
    
    state.lastHistoryCapture = new Date().format("EEE MMM dd, h:mm:ss a", location.timeZone)
    logDebug "--- Signal History Capture Complete ---"
    logTime("Finished captureSignalHistory")
}

// Helper to calculate relative time
def getTimeAgo(Long millis) {
    if (!millis) return "No changes recorded"
    def diff = (now() - millis) / 1000
    if (diff < 60) return "Just now"
    if (diff < 3600) return "${(int)(diff/60)}m ago"
    if (diff < 86400) return "${(int)(diff.toLong() / 3600)}h ${(int)((diff.toLong() % 3600) / 60)}m ago" 
    // return "${(int)(diff.toLong() / 86400)}d ${String.format('%.2f', ((diff.toLong() % 86400) / 3600.0))}h ago" // 1d 3.25h ago
    //return "${(int)(diff.toLong() / 86400)}d ${String.format('%dh:%02dm', (int)((diff.toLong() % 86400) / 3600), (int)((diff.toLong() % 3600) / 60))} ago" // 1d 7h:02m ago
    return "${(int)(diff.toLong() / 86400)}d ${(int)((diff.toLong() % 86400) / 3600)}h ${(int)((diff.toLong() % 3600) / 60)}m ago" // 1d 7h 2m ago
    // return "${(int)(diff.toLong() / 86400)}d ${String.format('%d:%02d', (int)((diff.toLong() % 86400) / 3600), (int)((diff.toLong() % 3600) / 60))} ago" // 1d 7:02 ago
}


def getDuration(long millis) {
    long seconds = millis / 1000
    long days = seconds / 86400
    long hours = (seconds % 86400) / 3600
    long minutes = (seconds % 3600) / 60
    
    if (days > 0) return "${days}d ${hours}h"
    if (hours > 0) return "${hours}h ${minutes}m"
    return "${minutes}m"
}

