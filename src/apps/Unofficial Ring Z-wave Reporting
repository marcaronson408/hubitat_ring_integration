                html << """
                <div style='display: flex; flex-direction: column; background: white; border: 1px solid #d1d5db; border-radius: 4px; padding: 4px 8px; min-width: 160px; box-shadow: 0 1px 1px rgba(0,0,0,0.05);'>
                    <div style='font-weight: bold; font-size: 12px; color: #111; margin-bottom: 2px; border-bottom: 1px solid #f0f0f0; padding-bottom: 2px;'>${n.name}</div>
                    <div style='display: flex; justify-content: space-between; align-items: center; gap: 10px;'>
                        <span style='font-size: 12px; color: ${getSignalColor(n.rssi, threshold, n.quality == "ok")}; font-weight: 600;'>${n.rssi} <small style='font-weight: normal; color: #999;'>dBm</small></span>
                        <div style='display: flex; gap: 3px;'>
                            <span title='Quality' style='font-size: 9px; padding: 0px 4px; border-radius: 3px; background: ${qColor}; color: white; font-weight: bold;'>${n.quality.toUpperCase()}</span>
