void logManualHistory(String zid) {
    // Access the state objects
    def history = state.rssiHistory ? state.rssiHistory[zid] : null
    def info = state.deviceInfo ? state.deviceInfo[zid] : null

    if (!history) {
        log.warn "No rssiHistory found for ZID: ${zid}"
        return
    }
    
    if (!info) {
        log.warn "No deviceInfo found for ZID: ${zid}"
        return
    }

    long firstMs = info.firstRecord ? info.firstRecord.toLong() : 0
    String deviceName = info.name ?: "Unknown"

    log.info "--- START DECODE: ${deviceName} ---"
    
    // Check if we have a valid anchor for time calculation
    if (firstMs > 0) {
        log.info "Anchor Date: ${new Date(firstMs).format('EEE, MMM d, yyyy HH:mm:ss', location.timeZone)}"
    } else {
        log.warn "No firstRecord anchor found. Timestamps will be relative offsets only."
    }

    history.eachWithIndex { packed, i ->
        // This calls your existing decodeRSSIHistory method
        Map data = decodeRSSIHistory(packed as int)
        
        // Reconstruct the timestamp
        String timeStr = "N/A"
        if (firstMs > 0) {
            long entryTimeMs = firstMs + (data.minutes.toLong() * 60000)
            timeStr = new Date(entryTimeMs).format("MM/dd HH:mm:ss", location.timeZone)
        }

        // Determine Path
        String path = (data.nodeId == 1) ? "HUB" : "NODE ${data.nodeId}"
        
        // Log the unpacked data
        log.info "[${i}] ${timeStr} | Path: ${path.padRight(8)} | RSSI: ${data.rssi} dBm | Quality: ${data.quality}"
    }
    
    log.info "--- END DECODE ---"
}

