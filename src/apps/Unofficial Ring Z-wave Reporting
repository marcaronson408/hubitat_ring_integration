@Field static Long lastLogTime = 0

def logTime(String label) {
    if ( !logTiming ) return
    long currentTime = now()
    
    String elapsedMsg = ""
    if (lastLogTime > 0) {
        long elapsed = currentTime - lastLogTime
        elapsedMsg = " (+${elapsed}ms)"
    }
    
    lastLogTime = currentTime // Update the memory-resident variable
    
    log.info "${label}: ${new Date(currentTime).format("HH:mm:ss.SSS")}${elapsedMsg}"
}

