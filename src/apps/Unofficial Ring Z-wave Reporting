            var dir = sortDirections[colIndex];
            sortDirections[colIndex] = -dir;
            
            mainRows.sort(function(a, b) {
                var aVal, bVal;
                if (type === "time") {
                    aVal = a.cells[colIndex].getAttribute("data-time") || 0;
                    bVal = b.cells[colIndex].getAttribute("data-time") || 0;
                    return (parseFloat(aVal) - parseFloat(bVal)) * dir;
                } else {
                    aVal = a.cells[colIndex].getAttribute("data-sort");
                    bVal = b.cells[colIndex].getAttribute("data-sort");
                    if (type === "number") return (parseFloat(aVal) - parseFloat(bVal)) * dir;
                    return aVal.localeCompare(bVal) * dir;
                }
            });
            
            mainRows.forEach(function(row, index) {
                var zid = row.getAttribute('data-zid');
                var neighRow = document.getElementById('neigh-' + zid);
                row.style.backgroundColor = (index % 2 === 0) ? "#ffffff" : "#f9f9f9";
                tbody.appendChild(row);
                if (neighRow) tbody.appendChild(neighRow);
            });
