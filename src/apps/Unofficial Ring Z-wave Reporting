                    <div style='display: flex; justify-content: space-between; align-items: center;'>
                        <span style='font-size: 12px; color: ${c.isStale ? "#999" : c.color}; font-weight: 600;'>${c.rssi} <small style='font-weight: normal; color: #999;'>dBm</small></span>
                    </div>
                    <div style='font-size: 10px; color: #888; margin-top: 2px;'>${c.timeStr}</div>
                </div>"""
            }
            html << "</div>"
        }
        html << "</td></tr>"
    }
    html << "</table>"
    return html.join("")
}

def getSignalIcon(rssi, isExtender, threshold, isOk = false) {
    // Determine the color
    def color = getSignalColor(rssi, threshold, isOk)
    // log.debug "result of getsignalcolor2(${rssi},${threshold},${isOk}) is ${color}"
    


    def baseStyle = "display: inline-block; width: 18px; height: 18px; background-color: ${color}; vertical-align: middle; margin-right: 3px;"
    
    if (isExtender) {
        // A square with a tiny 2px rounding to make it look professional
        def squareStyle = "border-radius: 2px;" 
        return "<span style='${baseStyle} ${squareStyle}'></span>"
    } else {
        return "<span style='${baseStyle} border-radius: 50%;'></span>"
    }
    
}

/**
 * Determines the signal color based on RSSI, threshold, and path quality.
 */
def getSignalColor(rssi, threshold, isOk = false) {
    def r = rssi.toInteger()
    def t = threshold.toInteger()

    // 1. Excellent, green
    if (r >= t) {
        return "#2E7D32" 
    }

    // 2. Good: blue (Within 10dB of threshold)
    if (r >= (t - 10)) {
        return "#9CCC65" 

    }
    
    // 3. Fair: Amber (Weak signal, but the Hub says it's 'OK' or 'Valid')
    if (isOk) {
        return "#FFC107" 
    } 
    
    // 4. Poor: Red (Weak signal AND the Hub reports issues)
    else {
        return "#C62828" 
    }
}

// Helpers

def rssiNormalize(rssi) {
    if (rssi == null || rssi == "") return -124
    int r = rssi.toInteger()
    if (r >= 125) return -r
    else if (r == 0) return -124
    else return r
}

import groovy.transform.Field

// --- BITMAP LAYOUT CONFIGURATION (13-bit Minutes) ---
// Total 32-bit Integer: [FF][NNNNNNNN][QQ][RRRRRRR][MMMMMMMMMMMMM]
// Bits 30-31: Future Use
// Bits 22-29: Node ID (8 bits)
// Bits 20-21: Quality (2 bits)
// Bits 13-19: RSSI    (7 bits)
// Bits 0-12:  Minutes (13 bits: Max 8,191)

@Field static final int BIT_SHIFT_NODE    = 22
@Field static final int BIT_SHIFT_QUALITY = 20
@Field static final int BIT_SHIFT_RSSI    = 13
@Field static final int BIT_SHIFT_MINS    = 0

@Field static final int MASK_NODE         = 0xFF
@Field static final int MASK_QUALITY      = 0x03
@Field static final int MASK_RSSI         = 0x7F
@Field static final int MASK_MINS         = 0x1FFF

/**
 * BITMAP ENCODING
 */
int encodeRSSIHistory(nodeId, qualityStatus, rssi, minutes) {
    int n = (nodeId.toInteger()) & MASK_NODE
    
    int q = 0
    if (qualityStatus instanceof Integer) {
        q = qualityStatus & MASK_QUALITY
    } else {
        String status = qualityStatus?.toString()?.toLowerCase()
        q = ((status == "ok" || status == "valid") ? 1 : (status == "poor" ? 2 : 0)) & MASK_QUALITY
    }
    
    int r = Math.abs(rssi.toInteger()) & MASK_RSSI
    int m = Math.min(MASK_MINS, minutes.toInteger()) & MASK_MINS

    return (n << BIT_SHIFT_NODE) | 
           (q << BIT_SHIFT_QUALITY) | 
           (r << BIT_SHIFT_RSSI) | 
           (m << BIT_SHIFT_MINS)
}

/**
 * BITMAP DECODING
 */
Map decodeRSSIHistory(int packed) {

    // BITMAP DECODE
    return [
        nodeId:  (packed >> BIT_SHIFT_NODE)    & MASK_NODE,
        quality: (packed >> BIT_SHIFT_QUALITY) & MASK_QUALITY,
        rssi:   -((packed >> BIT_SHIFT_RSSI)   & MASK_RSSI),
        minutes: (packed >> BIT_SHIFT_MINS)    & MASK_MINS,
        format: "bitmap"
    ]
}


